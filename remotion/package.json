{
  "name": "@sessionmovie/renderer",
  "version": "0.0.1",
  "description": "Remotion renderer for sessionmovie \u2014 the classic genre pack.",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.484",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.484",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render src/index.ts Classic ../out/sample.mp4 --props=../fixtures/screenplays/sample.json",
    "contact-sheet": "remotion still src/index.ts ContactSheet ../out/contact-sheet.png --frame=45",
    "build": "remotion bundle",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
